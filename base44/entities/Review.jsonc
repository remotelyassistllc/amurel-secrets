{
  "name": "Review",
  "type": "object",
  "properties": {
    "product_id": {
      "type": "string"
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "reviewer_name": {
      "type": "string"
    }
  },
  "required": [
    "product_id",
    "rating",
    "content"
  ]
}